# API
API_PORT=8080
API_HOST=0.0.0.0
APP_ENV=development

# Database
DATABASE_URL=postgres://petcontrol:petcontrol@localhost:5432/petcontrol?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=petcontrol
POSTGRES_USER=petcontrol
POSTGRES_PASSWORD=petcontrol
PGADMIN_PORT=5050

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
ASYNQMON_PORT=8081

# JWT
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

# Google Cloud Storage
GCS_PROJECT_ID=petcontrol-dev
GCS_BUCKET=petcontrol-uploads
GCS_CREDENTIALS_FILE=secrets/secret-gcs.json

# WhatsApp
WHATSAPP_API_URL="https://graph.facebook.com/v22.0/"
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCOUNT_ID=

# Worker
WORKER_CONCURRENCY=5
WORKER_QUEUE=default

# Local tooling
SQLC_VERSION=v1.30.0
GO_VERSION=1.26.1
NODE_VERSION=lts
PNPM_VERSION=10
POSTGRES_VERSION=18

# Web
VITE_API_URL=http://localhost:8082/api/v1
VITE_AUTH_MODE=api
