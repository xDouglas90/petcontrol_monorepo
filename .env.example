# API
API_PORT=8080
API_HOST=0.0.0.0
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Database
DATABASE_URL=postgres://petcontrol:petcontrol@localhost:5432/petcontrol?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=petcontrol
POSTGRES_USER=petcontrol
POSTGRES_PASSWORD=petcontrol
PGADMIN_PORT=5050

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@petcontrol.local
SMTP_FROM_NAME=PetControl

# Para acessar a interface web do MailHog:
# http://localhost:8025

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_PORT=6379
ASYNQMON_PORT=8081

# JWT
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_TTL=15m

# Google Cloud Storage
GCS_PUBLIC_URL=https://storage.googleapis.com/petcontrol-uploads/
GCS_PROJECT_ID=petcontrol-dev
GCS_BUCKET=petcontrol-uploads
GCS_CREDENTIALS_FILE=secrets/secret-gcs.json

# WhatsApp
WHATSAPP_API_URL=https://graph.facebook.com/v22.0/
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCOUNT_ID=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=

# Worker
WORKER_HTTP_ADDR=:8091
WORKER_CONCURRENCY=5
WORKER_QUEUE=default

# Local tooling
SQLC_VERSION=v1.30.0
GO_VERSION=1.26.1
NODE_VERSION=lts
PNPM_VERSION=10
POSTGRES_VERSION=18

# Web
VITE_API_URL=http://localhost:8080/api/v1
VITE_AUTH_MODE=api
