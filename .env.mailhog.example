# MailHog (SMTP local para desenvolvimento)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@petcontrol.local
SMTP_FROM_NAME=PetControl

# Para acessar a interface web do MailHog:
# http://localhost:8025

# Para integração do worker de emails:
# Configure o worker para usar SMTP_HOST, SMTP_PORT, SMTP_USERNAME,
# SMTP_PASSWORD, SMTP_FROM_EMAIL e SMTP_FROM_NAME
# Exemplo de configuração para desenvolvimento:
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USERNAME= (deixe vazio)
# SMTP_PASSWORD= (deixe vazio)
# SMTP_FROM_EMAIL=no-reply@petcontrol.local
# SMTP_FROM_NAME=PetControl
